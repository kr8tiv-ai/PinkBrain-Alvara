# Etherscan API key (V2 unified key) — works for Base, Ethereum, all chains
# Get one at https://etherscan.io/apis
# Without a key, API calls are severely rate-limited
BASESCAN_API_KEY=

# Private key for signing transactions (BSKT creation in T02)
# DO NOT commit this file — use .env locally
PRIVATE_KEY=

# Solana RPC URL — defaults to https://api.mainnet-beta.solana.com if unset
# For production bridging, use a private RPC (Helius, QuickNode, etc.)
SOL_RPC_URL=

# Solana private key (base58 encoded) — for signing bridge transactions
# DO NOT commit real keys. Use .env locally.
SOL_PRIVATE_KEY=

# Bags FM API key — required for fee share admin and claiming operations
# Get one at https://dev.bags.fm
BAGS_API_KEY=
